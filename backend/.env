# Environment
ENVIRONMENT=development
PORT=8080
READ_TIMEOUT=10
WRITE_TIMEOUT=10

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=navhub
DB_PASSWORD=navhub_password
DB_NAME=navhub

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24
REFRESH_EXPIRY=7

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_URL=http://localhost:8080/api/v1/auth/oauth

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@navhub.com

# Frontend
FRONTEND_URL=http://localhost:5173
