# NavHub 部署配置文件

# 服务器配置
SERVER_HOST=117.72.39.169
SERVER_USER=root
SERVER_PATH=/data/web

# 域名配置
DOMAIN=hao246.cn
DOMAIN_WWW=www.hao246.cn

# 本地路径
PROJECT_ROOT=/Users/mac-new/work/navhub
FRONTEND_PATH=${PROJECT_ROOT}/frontend
BACKEND_PATH=${PROJECT_ROOT}/backend

# 服务端口
BACKEND_PORT=8080
FRONTEND_PORT=5173

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=navhub
DB_USER=navhub
DB_PASSWORD=navhub_password

# 环境变量
ENVIRONMENT=production
NODE_ENV=production

# Nginx配置
NGINX_CONFIG_PATH=/etc/nginx/conf.d/navhub.conf

# 日志路径
LOG_PATH=${SERVER_PATH}/logs
BACKEND_LOG=${LOG_PATH}/backend.log
NGINX_ACCESS_LOG=${LOG_PATH}/nginx-access.log
NGINX_ERROR_LOG=${LOG_PATH}/nginx-error.log

# SSL证书路径（如果使用HTTPS）
SSL_CERT_PATH=${SERVER_PATH}/ssl/cert.pem
SSL_KEY_PATH=${SERVER_PATH}/ssl/key.pem

# 备份路径
BACKUP_PATH=${SERVER_PATH}/backups

# Git配置（如果从Git拉取）
GIT_REPO=
GIT_BRANCH=main
